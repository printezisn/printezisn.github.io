{
  "name": "nikos-printezis-website",
  "type": "module",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">= 22.13.1",
    "pnpm": ">= 10"
  },
  "scripts": {
    "start:dev": "astro dev --port 3000",
    "start:prod": "astro preview --port 4000",
    "build": "astro build && node ./sanitize-sitemap",
    "prepare": "husky",
    "prettier:format": "prettier --write .",
    "lint": "astro check --minimumSeverity warning && eslint ./src",
    "lint:fix": "astro check --minimumSeverity warning && eslint ./src --fix",
    "sanitize-post": "node ./sanitize-post"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@printezisn/games-sudoku@1.1.0",
      "@printezisn/games-couples-run@1.7.3",
      "@printezisn/solidboy@0.2.4"
    ]
  },
  "dependencies": {
    "@astrojs/check": "0.9.8",
    "@astrojs/mdx": "5.0.3",
    "@astrojs/sitemap": "3.7.2",
    "@fontsource/lora": "5.1.0",
    "@fontsource/roboto": "5.1.0",
    "@printezisn/games-couples-run": "git://github.com/printezisn/games-couples-run#v1.7.3",
    "@printezisn/games-sudoku": "git://github.com/printezisn/games-sudoku#v1.1.0",
    "@printezisn/solidboy": "git://github.com/printezisn/solidboy#0.2.4",
    "astro": "6.1.5",
    "astro-expressive-code": "0.41.7",
    "feather-icons": "4.29.2",
    "husky": "9.1.7",
    "invokers-polyfill": "^1.0.3",
    "sass": "1.98.0",
    "sharp": "0.34.5",
    "typescript": "6.0.2",
    "vite-plugin-static-copy": "4.0.0"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@typescript-eslint/parser": "8.58.0",
    "eslint": "10.1.0",
    "eslint-plugin-astro": "1.6.0",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "globals": "17.4.0",
    "jsdom": "29.0.1",
    "prettier": "3.8.1",
    "prettier-plugin-astro": "0.14.1",
    "typescript-eslint": "8.57.2"
  }
}
